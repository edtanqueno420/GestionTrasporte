{
  "info": {
    "name": "QuitoMove Demo API",
    "description": "Colección completa PK-based para demo de QuitoMove Smart Mobility. Flujo: Auth → Catálogos → Rutas/Paradas → Operaciones → GPS → Incidentes → Analytics → Público.\n\nEjecutar seed primero: python manage.py seed_demo\n\nVariables pre-configuradas con IDs del seed:\n  route_id=5 (RT-ECO), vehicle_id=2 (ECO-001), trip_id=2 (en curso)\n  driver_id=2 (conductor1), schedule_id=1, incident_type_id=2 (Accidente)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "route_id", "value": "5", "type": "string" },
    { "key": "vehicle_id", "value": "2", "type": "string" },
    { "key": "trip_id", "value": "2", "type": "string" },
    { "key": "driver_id", "value": "2", "type": "string" },
    { "key": "schedule_id", "value": "1", "type": "string" },
    { "key": "incident_id", "value": "", "type": "string" },
    { "key": "incident_type_id", "value": "2", "type": "string" },
    { "key": "bus_stop_id", "value": "1", "type": "string" },
    { "key": "user_id", "value": "5", "type": "string" }
  ],
  "item": [
