  "item": [
    {
      "name": "🔐 Auth",
      "description": "Tablas: accounts_user (Register/Login/Me), accounts_profile (Update Profile), accounts_audit_log (indirecto por signals al login/register/change-password)\n\n🔄 ORDEN: 1. Login primero → token + user_id se auto-asignan vía test script",
      "item": [
        {
          "name": "Register",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "const json = pm.response.json();", "pm.collectionVariables.set('user_id', json.data.id);"], "type": "text/javascript"}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"username\": \"demo_user\",\n  \"password\": \"demo123\",\n  \"email\": \"demo@test.com\"\n}"}, "url": {"raw": "{{base_url}}/api/auth/register/", "host": ["{{base_url}}"], "path": ["api", "auth", "register"]}}
        },
        {
          "name": "Login (admin - prod)",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.collectionVariables.set('token', json.access);", "pm.collectionVariables.set('refresh_token', json.refresh);", "// Auto-fetch user ID from /me/ endpoint", "pm.sendRequest({", "  url: pm.variables.replaceIn('{{base_url}}/api/auth/me/'),", "  method: 'GET',", "  header: { Authorization: 'Bearer ' + json.access }", "}, function (err, res) {", "  if (!err) { const me = res.json(); pm.collectionVariables.set('user_id', me.id); }", "});"], "type": "text/javascript"}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"username\": \"moviecoreadmin\",\n  \"password\": \"tanqueno123\"\n}"}, "url": {"raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login"]}}
        },
        {
          "name": "Login (admin - local)",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.collectionVariables.set('token', json.access);", "pm.collectionVariables.set('refresh_token', json.refresh);", "// Auto-fetch user ID from /me/ endpoint", "pm.sendRequest({", "  url: pm.variables.replaceIn('{{base_url}}/api/auth/me/'),", "  method: 'GET',", "  header: { Authorization: 'Bearer ' + json.access }", "}, function (err, res) {", "  if (!err) { const me = res.json(); pm.collectionVariables.set('user_id', me.id); }", "});"], "type": "text/javascript"}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"}, "url": {"raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login"]}}
        },
        {
          "name": "Login (conductor)",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.collectionVariables.set('token', json.access);", "pm.collectionVariables.set('refresh_token', json.refresh);", "// Auto-fetch user ID from /me/ endpoint", "pm.sendRequest({", "  url: pm.variables.replaceIn('{{base_url}}/api/auth/me/'),", "  method: 'GET',", "  header: { Authorization: 'Bearer ' + json.access }", "}, function (err, res) {", "  if (!err) { const me = res.json(); pm.collectionVariables.set('user_id', me.id); }", "});"], "type": "text/javascript"}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"username\": \"conductor1\",\n  \"password\": \"demo123\"\n}"}, "url": {"raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login"]}}
        },
        {
          "name": "Refresh Token",
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"}, "url": {"raw": "{{base_url}}/api/auth/refresh/", "host": ["{{base_url}}"], "path": ["api", "auth", "refresh"]}}
        },
        {
          "name": "Get Me",
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": {"raw": "{{base_url}}/api/auth/me/", "host": ["{{base_url}}"], "path": ["api", "auth", "me"]}}
